#!/bin/sh
export PATH="/usr/local/bin:/usr/bin:/bin:$HOME/.local/bin:$HOME/scripts"

choice=$(for d in $(echo $PATH | tr : '\n'); do find "$d" -maxdepth 1 -executable -type f -printf '%f\n' 2>/dev/null; done | sort -u | wmenu -f "DejaVu Sans Bold 16")

if printf '%s' "$choice" | grep -qE '^[0-9+*/^() ]+$'; then
    expr=$(printf '%s' "$choice" | sed 's/\^/**/g')
    result=$(python3 -c "from math import *; print($expr)" 2>/dev/null || echo 'error')
    printf '%s' "$result" | wl-copy
    notify-send -t 6000 "$result"
elif [ -n "$choice" ]; then
    /bin/sh -c "$choice" &
fi
